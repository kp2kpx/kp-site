# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# IPNS signing key. NEVER commit. Paste into GitHub Secrets, then delete locally.
IPNS_SIGNING_KEY.secret.txt
/scripts/_genkey_tmp.mjs

# Local IPFS packaging scratch artifacts
/out.car
/out_extracted

# Belt and suspenders: never commit any private key material.
*.key
*.key.bin
*.bin
*key*.txt
*.secret.txt
*.secret
